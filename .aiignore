# ==============================================================================
# .aiignore — AI Agent Token Optimization
# Blocks heavy directories from AI scanning to save context window tokens
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Flutter / Dart Tooling (largest token consumers)
# ──────────────────────────────────────────────────────────────────────────────
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies

# ──────────────────────────────────────────────────────────────────────────────
# Build Output — NEVER scan
# ──────────────────────────────────────────────────────────────────────────────
build/

# ──────────────────────────────────────────────────────────────────────────────
# Android Build & Gradle Caches
# ──────────────────────────────────────────────────────────────────────────────
android/.gradle/
android/app/build/
android/gradle/

# ──────────────────────────────────────────────────────────────────────────────
# iOS — CocoaPods & Symlinks (10K+ files)
# ──────────────────────────────────────────────────────────────────────────────
ios/Pods/
ios/.symlinks/
ios/Flutter/

# ──────────────────────────────────────────────────────────────────────────────
# macOS / Linux / Windows Ephemeral Build Caches
# ──────────────────────────────────────────────────────────────────────────────
macos/
linux/
windows/flutter/ephemeral/

# ──────────────────────────────────────────────────────────────────────────────
# Lock Files & Generated Code (only scan on demand)
# ──────────────────────────────────────────────────────────────────────────────
pubspec.lock
lib/generated/
lib/core/di/injection.config.dart

# ──────────────────────────────────────────────────────────────────────────────
# Git, IDE, OS artifacts
# ──────────────────────────────────────────────────────────────────────────────
.git/
.idea/
.vscode/
.DS_Store

# ──────────────────────────────────────────────────────────────────────────────
# Environment & Credentials
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*
**/google-services.json
**/GoogleService-Info.plist

# ──────────────────────────────────────────────────────────────────────────────
# CI / CD Workflows (rarely relevant to coding tasks)
# ──────────────────────────────────────────────────────────────────────────────
.github/

# ──────────────────────────────────────────────────────────────────────────────
# Test output & coverage
# ──────────────────────────────────────────────────────────────────────────────
coverage/
test/
